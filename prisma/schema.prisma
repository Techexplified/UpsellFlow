// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model UpsellOffer {
  id                      String   @id @default(uuid())
  shop                    String
  type                    String   // "SIZE_UPGRADE" or "PACK_UPGRADE"
  triggerProductId        String?
  triggerProductTitle     String?
  triggerParentProductId  String?
  triggerProductImage     String?
  upgradeProductId        String?
  upgradeProductTitle     String?
  upgradeParentProductId  String?
  upgradeProductImage     String?
  priceDifference         Float?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model UpsellSettings {
  id                     String   @id @default(uuid())
  shop                   String   @unique
  thankYouWidgetEnabled  Boolean  @default(true)
  referralWidgetEnabled  Boolean  @default(true)
  discountWidgetEnabled  Boolean  @default(true)
  discountCode           String   @default("NEXT10")
  timerDuration          Int      @default(15)
  isActive               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  shop        String
  featureType String   // "SWAP", "THANK_YOU_UPSELL", "DISCOUNT_WIDGET", "REFERRAL_WIDGET"
  eventType   String   // "IMPRESSION" or "CONVERSION"
  revenue     Float    @default(0.0)
  offerId     String?  // optional: links to UpsellOffer.id for per-offer analytics
  createdAt   DateTime @default(now())
}
